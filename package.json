{
  "name": "@curatedmcp/launcher",
  "version": "1.0.1",
  "description": "The MCP Hub — one config that connects every AI agent (Claude, Cursor, Windsurf, Copilot, Gemini) to every MCP server you register",
  "license": "MIT",
  "type": "module",
  "bin": {
    "launcher": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "!dist/__tests__/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-hub",
    "mcp-server",
    "mcp-client",
    "mcp-gateway",
    "mcp-proxy",
    "mcp-orchestrator",
    "launcher",
    "install",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "cursor",
    "windsurf",
    "copilot",
    "gemini",
    "anthropic",
    "ai-tools",
    "ai-agent",
    "agent-orchestration",
    "discovery"
  ],
  "author": "CuratedMCP",
  "homepage": "https://curatedmcp.com/launcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/oneprofile-dev/mcp-launcher"
  },
  "bugs": {
    "url": "https://github.com/oneprofile-dev/mcp-launcher/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^1.0.0"
  }
}
